{
  "name": "hearth",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm --workspace @hearth/web run dev",
    "dev:api": "npm --workspace @hearth/api run dev",
    "deploy:web": "npm --workspace @hearth/web run deploy",
    "deploy:api": "npm --workspace @hearth/api run deploy",
    "deploy:first:dry": "powershell -ExecutionPolicy Bypass -File scripts/cloudflare-first-deploy.ps1 -AutoCreatePagesProject -DryRun",
    "deploy:first": "powershell -ExecutionPolicy Bypass -File scripts/cloudflare-first-deploy.ps1 -AutoCreatePagesProject",
    "smoke:postdeploy": "powershell -ExecutionPolicy Bypass -File scripts/post-deploy-smoke.ps1",
    "governance:gate": "powershell -ExecutionPolicy Bypass -File scripts/governance-phase-gate.ps1",
    "readiness:first:codeonly": "powershell -ExecutionPolicy Bypass -File scripts/first-release-readiness.ps1 -SkipEnv -SkipWebBuild -SkipGovernanceGate",
    "readiness:first": "powershell -ExecutionPolicy Bypass -File scripts/first-release-readiness.ps1 -SkipWebBuild",
    "readiness:first:strict": "powershell -ExecutionPolicy Bypass -File scripts/first-release-readiness.ps1",
    "build": "npm run build --workspaces",
    "check": "npm run check --workspaces"
  },
  "engines": {
    "node": ">=20"
  }
}
