{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "hearth-api",
  "main": "src/index.ts",
  "compatibility_date": "2026-03-21",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "vars": {
    "APP_ENV": "development"
  },
  "observability": {
    "enabled": true
  },
  "triggers": {
    "crons": ["0 6 * * 1-5"]
  }
}
